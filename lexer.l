%{\n#include <stdio.h>\n#include <stdlib.h>\n\nint lineno = 1;\n%}\n\n%option noyywrap\n\n%%\n[ \t]+          ; // Ignore whitespace\n\n\n             { lineno++; }\n"//".*         ; // Ignore single-line comments\n"/*"([^*]|\*+[^*/])*"*/"   ; // Ignore multi-line comments\n\n"if"           { return IF; }\n"else"         { return ELSE; }\n"while"        { return WHILE; }\n"return"       { return RETURN; }\n\n[0-9]+         { yylval.intValue = atoi(yytext); return NUMBER; }\n"\"([^\"\\]|\\.)*\"" { return STRING; }\n\n"+"            { return PLUS; }\n"-"            { return MINUS; }\n"*"            { return STAR; }\n"/"            { return SLASH; }\n\n"=="           { return EQ; }\n"!="           { return NE; }\n"<"            { return LT; }\n"<="           { return LE; }\n">"            { return GT; }\n">="           { return GE; }\n\n"="            { return ASSIGN; }\n\n[;]            { return SEMICOLON; }\n[()]           { return PAREN; }\n[{}]           { return CURLY; }\n\n.              { fprintf(stderr, "Lexical error at line %d: Unrecognized character: %s\n", lineno, yytext); }\n\n%%\n